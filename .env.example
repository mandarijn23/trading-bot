# Stock Trading Bot Configuration
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Stocks to trade
STOCK_SYMBOLS=["SPY","QQQ","VOO"]
STOCK_UNIVERSE_SYMBOLS=SPY,QQQ,VOO,IWM,DIA,XLK,XLF,XLE,SMH,NVDA,AAPL,MSFT,AMZN,META,TSLA,AMD,GOOGL
STOCK_DYNAMIC_SELECTION=true
STOCK_DYNAMIC_SYMBOL_COUNT=6
STOCK_SELECTION_REFRESH_CYCLES=8
STOCK_SYMBOL_TIER_A=IWM,XLK,GOOGL,QQQ
STOCK_SYMBOL_TIER_B=SPY,VOO,DIA,XLF,XLE,SMH,AAPL,MSFT,AMZN,META,AMD
STOCK_SYMBOL_TIER_C=TSLA,NVDA
STOCK_TIER_WEIGHT_A=1.00
STOCK_TIER_WEIGHT_B=0.75
STOCK_TIER_WEIGHT_C=0.00
STOCK_TIMEFRAME=15Min

# RSI Settings
STOCK_RSI_PERIOD=14
STOCK_RSI_OVERSOLD=35
STOCK_RSI_OVERBOUGHT=65

# Position Size
STOCK_TRADE_AMOUNT=25.0
STOCK_MIN_TRADE_AMOUNT=10.0

# Risk Management
STOCK_STOP_LOSS=0.035
STOCK_TAKE_PROFIT=0.07
STOCK_TRAILING_STOP=0.025
STOCK_COOLDOWN=4
STOCK_MAX_DAILY_LOSS=0.05
STOCK_MAX_OPEN_POS=3
STOCK_MIN_DOLLAR_VOLUME=1500000
STOCK_MIN_ATR_PCT=0.004
STOCK_MAX_ATR_PCT=0.10

# Trading Mode
STOCK_PAPER_TRADING=true
STOCK_CHECK_INTERVAL=60
STOCK_LOG_LEVEL=INFO
STOCK_LOG_MAX_MB=10
STOCK_LOG_BACKUP_COUNT=7
STOCK_DECISION_TRACE_ENABLED=true
STOCK_DECISION_TRACE_TO_CONSOLE=false
STOCK_DECISION_TRACE_FILE=logs/decision_trace.jsonl

# AI
STOCK_USE_AI=true
STOCK_MIN_AI_CONFIDENCE=0.40
STOCK_MIN_AI_CONFIDENCE_UPTREND=0.48
STOCK_MIN_AI_CONFIDENCE_RANGING=0.55
STOCK_MIN_AI_CONFIDENCE_DOWNTREND=0.62
STOCK_REGIME_WEIGHT_UPTREND=1.00
STOCK_REGIME_WEIGHT_RANGING=0.70
STOCK_REGIME_WEIGHT_DOWNTREND=0.50

# External data and gating
STOCK_EXTERNAL_SIGNALS_ENABLED=false
STOCK_EXTERNAL_SIGNAL_CACHE_TTL=300
STOCK_EXTERNAL_SIGNAL_TIMEOUT_SEC=3.0
STOCK_EXTERNAL_SIGNAL_MIN_CONFIDENCE=0.35
STOCK_EXTERNAL_SENTIMENT_MIN=-0.35
STOCK_EXTERNAL_CATALYST_MIN=0.20
STOCK_EXTERNAL_EVENT_RISK_MAX=0.85
STOCK_EXTERNAL_SYMBOL_WEIGHT=0.05
STOCK_ENFORCE_MODEL_QUALITY_GATE=false
STOCK_MODEL_QUALITY_REPORT_PATH=training_report.json
STOCK_MODEL_MIN_AUC=0.53
STOCK_MODEL_MIN_F1=0.53
STOCK_MODEL_MIN_HOLDOUT_SAMPLES=60
STOCK_DECAY_GATE_ENABLED=true
STOCK_DECAY_GATE_CHECK_CYCLES=10
STOCK_DECAY_GATE_FILE=logs/strategy_gate.json
STOCK_DECAY_GATE_DAILY_LOSS_FRACTION=0.5

# Optional external feeds
NEWS_API_KEY=
TWITTER_BEARER_TOKEN=
ECONOMIC_CALENDAR_API_KEY=
STOCK_EXTERNAL_SIGNAL_FILE=logs/external_signals.json

# Discord notifications
DISCORD_WEBHOOK_URL=
